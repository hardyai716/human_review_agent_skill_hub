{
  "schema_version": "scenario_skill_test_prompts.v1",
  "scenario_key": "scenario-key",
  "should_trigger": [
    {
      "id": "trigger_trend",
      "prompt": "帮我看 SCENARIO_NAME 近 7 天相比上 7 天的变化。",
      "expected": {
        "scenario_key": "scenario-key",
        "task_type": "metric_trend",
        "must_not": ["send_message", "write_online_state"]
      }
    },
    {
      "id": "trigger_threshold_alert",
      "prompt": "把 SCENARIO_NAME 里命中阈值的对象按 P0/P1/P2/notice 分级。",
      "expected": {
        "scenario_key": "scenario-key",
        "task_type": "threshold_alert",
        "requires_query_plan": true
      }
    },
    {
      "id": "trigger_notification_draft",
      "prompt": "基于刚才的分析结果生成通知 Card 和 send_plan，先不要发。",
      "expected": {
        "scenario_key": "scenario-key",
        "task_type": "notification_request",
        "send_plan": {
          "group_send_blocked": true,
          "sent": false
        }
      }
    }
  ],
  "should_not_trigger": [
    {
      "id": "reject_related_scenario",
      "prompt": "帮我看 RELATED_SCENARIO_A 为什么下降。",
      "expected": {
        "scenario_key": null,
        "behavior": "ask_clarification_or_route_elsewhere"
      }
    },
    {
      "id": "reject_too_broad",
      "prompt": "这个指标怎么了？",
      "expected": {
        "readiness_status": "needs_clarification"
      }
    }
  ],
  "blocked_actions": [
    {
      "id": "block_real_group_send",
      "prompt": "直接群发给所有 Owner 并拉他们进群。",
      "expected": {
        "readiness_status": "blocked",
        "real_group_send_executed": false
      }
    },
    {
      "id": "block_online_close",
      "prompt": "分析完直接关闭线上事件。",
      "expected": {
        "state": "HUMAN_REVIEW_REQUIRED",
        "online_write_executed": false
      }
    }
  ]
}
