{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.bytedance.local/human-review-ops/resolution-result.schema.json",
  "title": "HumanReviewOpsResolutionResult",
  "description": "Resolution 节点的本地调试闭环产物。",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "resolution_id",
    "event_id",
    "scenario_key",
    "actions",
    "manual_tracking",
    "state_machine",
    "source_refs",
    "closure_check",
    "closure",
    "follow_up",
    "safety"
  ],
  "properties": {
    "schema_version": {"const": "stage_2_manual_tracking.v1"},
    "resolution_id": {"type": "string"},
    "event_id": {"type": "string"},
    "scenario_key": {"type": "string"},
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "action_id",
          "action_type",
          "executor",
          "requires_confirmation",
          "status",
          "created_at"
        ]
      }
    },
    "manual_tracking": {
      "type": "object",
      "required": [
        "tracking_mode",
        "overall_status",
        "tracking_records",
        "continue_observation"
      ]
    },
    "state_machine": {
      "type": "object",
      "required": [
        "state_machine_ref",
        "previous_state",
        "current_state",
        "next_state"
      ],
      "properties": {
        "next_state": {
          "type": "string",
          "enum": [
            "MANUAL_TRACKING_RECORDED",
            "DEBUG_CLOSED",
            "HUMAN_REVIEW_REQUIRED"
          ]
        }
      }
    },
    "source_refs": {"type": "object"},
    "closure_check": {
      "type": "object",
      "required": ["can_close", "reason", "missing_before_close"],
      "properties": {
        "can_close": {"type": "boolean"},
        "reason": {"type": "string"},
        "missing_before_close": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "closure": {
      "type": "object",
      "required": [
        "action_completed",
        "evidence_confirmed",
        "conclusion_recorded",
        "root_cause",
        "impact_scope",
        "final_conclusion",
        "closed_by",
        "closed_at"
      ]
    },
    "follow_up": {
      "type": "object",
      "required": [
        "needs_iteration",
        "iteration_reasons",
        "abnormal_flags",
        "next_review_owner"
      ]
    },
    "safety": {
      "type": "object",
      "required": [
        "requires_confirmation",
        "group_send_blocked",
        "group_send_sent",
        "real_group_send_executed",
        "online_write_executed",
        "online_state_write_allowed"
      ]
    }
  }
}
