{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.bytedance.local/human-review-ops/analysis-result.schema.json",
  "title": "HumanReviewOpsAnalysisResult",
  "description": "人审运营分析阶段的统一结果结构。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "analysis_id",
    "event_id",
    "templates_used",
    "query_plan",
    "impact_assessment",
    "root_cause_hypotheses",
    "sop_decision",
    "readonly_execution",
    "quality_checks",
    "source_footer",
    "provenance"
  ],
  "properties": {
    "analysis_id": {"type": "string"},
    "event_id": {"type": "string"},
    "templates_used": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string"}
    },
    "query_plan": {"$ref": "#/$defs/query_plan"},
    "impact_assessment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "impact_scope",
        "risk_level",
        "business_risk",
        "duration",
        "evidence_refs"
      ],
      "properties": {
        "summary": {"type": "string"},
        "impact_scope": {"type": "string"},
        "risk_level": {
          "type": "string",
          "enum": ["P0", "P1", "P2", "notice", "none", "unknown"]
        },
        "business_risk": {"type": "string"},
        "duration": {"type": "string"},
        "evidence_refs": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "root_cause_hypotheses": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "hypothesis",
          "confidence",
          "supporting_evidence",
          "contradicting_evidence",
          "next_check"
        ],
        "properties": {
          "hypothesis": {"type": "string"},
          "confidence": {"type": "number", "minimum": 0, "maximum": 1},
          "supporting_evidence": {
            "type": "array",
            "items": {"type": "string"}
          },
          "contradicting_evidence": {
            "type": "array",
            "items": {"type": "string"}
          },
          "next_check": {"type": "string"}
        }
      }
    },
    "sop_decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "severity_level",
        "next_action",
        "required_confirmation",
        "matched_rules",
        "reason"
      ],
      "properties": {
        "severity_level": {
          "type": "string",
          "enum": ["P0", "P1", "P2", "notice", "none", "unknown"]
        },
        "next_action": {
          "type": "string",
          "enum": [
            "answer",
            "notify",
            "ask_more",
            "monitor",
            "external_readonly_execute",
            "execute_with_confirmation",
            "escalate"
          ]
        },
        "required_confirmation": {"type": "boolean"},
        "matched_rules": {
          "type": "array",
          "items": {"type": "string"}
        },
        "reason": {"type": "string"}
      }
    },
    "readonly_execution": {"$ref": "#/$defs/readonly_execution"},
    "quality_checks": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "evidence_complete",
        "data_fresh",
        "metric_definition_consistent",
        "owner_resolved",
        "confidence"
      ],
      "properties": {
        "evidence_complete": {"type": "boolean"},
        "data_fresh": {"type": "boolean"},
        "metric_definition_consistent": {"type": "boolean"},
        "owner_resolved": {"type": "boolean"},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "warnings": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "source_footer": {"$ref": "#/$defs/source_footer"},
    "provenance": {"$ref": "#/$defs/provenance"}
  },
  "$defs": {
    "query_plan": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "query_plan_id",
        "scenario_key",
        "task_type",
        "analysis_mode",
        "metric_id",
        "metric_entities",
        "time_range",
        "dimensions",
        "filters",
        "allowed_sources",
        "forbidden_sources",
        "quality_checks",
        "review_required"
      ],
      "properties": {
        "query_plan_id": {"type": "string"},
        "scenario_key": {"type": "string"},
        "task_type": {"type": "string"},
        "analysis_mode": {"type": "string"},
        "metric_id": {"type": "string"},
        "metric_entities": {"type": "array"},
        "time_range": {"type": "object"},
        "dimensions": {"type": "array", "items": {"type": "string"}},
        "filters": {"type": "array", "items": {"type": "string"}},
        "allowed_sources": {"type": "array", "items": {"type": "string"}},
        "forbidden_sources": {"type": "array", "items": {"type": "string"}},
        "quality_checks": {"type": "array", "items": {"type": "string"}},
        "review_required": {"type": "boolean"}
      }
    },
    "readonly_execution": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "execution_id",
        "execution_mode",
        "analysis_mode",
        "status",
        "source_tier",
        "data_freshness",
        "row_count",
        "truncated",
        "metric_formula",
        "quality_checks"
      ],
      "properties": {
        "execution_id": {"type": "string"},
        "execution_mode": {"type": "string"},
        "analysis_mode": {"type": "string"},
        "status": {
          "type": "string",
          "enum": ["success", "not_executed", "blocked", "degraded", "failed"]
        },
        "source_tier": {"type": "string"},
        "data_freshness": {"type": "string"},
        "row_count": {"type": "integer", "minimum": 0},
        "truncated": {"type": ["boolean", "null"]},
        "metric_formula": {"type": "string"},
        "quality_checks": {"type": "object"}
      }
    },
    "source_footer": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "source_tier",
        "metric_definition_version",
        "data_freshness",
        "owner",
        "confidence_tier",
        "review_status",
        "scenario_key",
        "metric_id",
        "query_plan_id",
        "time_window",
        "limitations",
        "run_mode"
      ],
      "properties": {
        "source_tier": {
          "type": "string",
          "enum": [
            "semantic_layer",
            "governed_dataset",
            "curated_raw_sql",
            "scenario_reference",
            "scenario_reference_preflight",
            "readonly_exploration",
            "mock_fixture"
          ]
        },
        "metric_definition_version": {"type": "string"},
        "data_freshness": {"type": "string"},
        "owner": {"type": "string"},
        "confidence_tier": {"type": "string", "enum": ["high", "medium", "low"]},
        "review_status": {
          "type": "string",
          "enum": [
            "not_reviewed",
            "auto_reviewed",
            "human_reviewed",
            "debug_only_no_real_query",
            "debug_only_mock_readonly_execution",
            "debug_only_execution_blocked",
            "real_readonly_query_executed"
          ]
        },
        "scenario_key": {"type": "string"},
        "metric_id": {"type": "string"},
        "query_plan_id": {"type": "string"},
        "time_window": {"type": "object"},
        "limitations": {"type": "array", "items": {"type": "string"}},
        "run_mode": {"type": "string"}
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "provenance_id",
        "scenario_key",
        "query_plan_id",
        "execution_id",
        "execution_mode",
        "source_tier",
        "source_name",
        "metric_id",
        "metric_formula",
        "tool_call_ids",
        "references",
        "limitations"
      ],
      "properties": {
        "provenance_id": {"type": "string"},
        "scenario_key": {"type": "string"},
        "query_plan_id": {"type": "string"},
        "execution_id": {"type": "string"},
        "execution_mode": {"type": "string"},
        "source_tier": {"type": "string"},
        "source_name": {"type": "string"},
        "metric_id": {"type": "string"},
        "metric_formula": {"type": "string"},
        "tool_call_ids": {"type": "array", "items": {"type": "string"}},
        "references": {"type": "object"},
        "limitations": {"type": "array", "items": {"type": "string"}}
      }
    }
  }
}
